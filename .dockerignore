# Virtualenv locale (ricreato dentro il container) e cache
.venv/
__pycache__/
*.pyc
*.pyo

# Git e metadati
.git/
.gitignore
.gitattributes

# Notebook di sperimentazione e file di test (non parte del runtime)
*.ipynb
temp_audio.wav

# Output operativi
logs/
backups/
screenshots/

# Segreti e modelli scaricati a runtime
.env*
model/

# Documentazione, test e utility di sviluppo che non servono nell'immagine.
# README.md è escluso dall'ignore perché il Dockerfile lo copia (build).
*.md
!README.md
docs/
scripts/
tests/
.github/
.pre-commit-config.yaml
