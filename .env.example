# =============================================================================
# Calliope — configurazione d'ambiente
# =============================================================================
# Copia questo file:
#   cp .env.example .env       # produzione (bot di prod)
#   cp .env.example .env.dev   # sviluppo (bot di dev)
#
# In sviluppo carica .env.dev impostando, prima di avviare:
#   export CALLIOPE_ENV_FILE=.env.dev
# In produzione/Docker il default (.env) va bene: il compose lo inietta.
# =============================================================================

# --- Telegram ---------------------------------------------------------------
# Token del bot ottenuto da BotFather (obbligatorio).
TELEGRAM_TOKEN="paste_your_bot_token_here"
# Chat ID dell'amministratore per le notifiche (opzionale). Lascialo vuoto o
# rimuovilo se non usi le notifiche admin.
ADMIN_CHAT_ID=

# --- MongoDB ----------------------------------------------------------------
# URI di connessione.
#   Docker  : mongodb://mongodb:27017   (già impostato nel docker-compose.yml)
#   Locale  : mongodb://localhost:27018 (porta host mappata dal compose)
MONGO_URI="mongodb://localhost:27018"
MONGO_DB_NAME="calliope"
MONGO_USERS_COLLECTION="users_db"
MONGO_GROUPS_COLLECTION="groups_db"

# --- Modello / trascrizione -------------------------------------------------
# Repository HuggingFace del modello faster-whisper.
WHISPER_MODEL="deepdml/faster-whisper-large-v3-turbo-ct2"
# Device di inferenza: auto (rileva GPU con fallback a CPU) | cuda | cpu.
DEVICE="auto"
# Indice della GPU da usare quando DEVICE=cuda.
DEVICE_INDEX=0
# Lingua di trascrizione forzata (es. "it", "en"). Vuoto = auto-detect.
DEFAULT_LANGUAGE=

# --- Limiti / runtime -------------------------------------------------------
# Soglia di rilevamento del silenzio (predisposta, usata in uno step futuro).
SILENCE_THRESHOLD=70
# Durata massima dei media accettati, in secondi (predisposta).
MAX_MEDIA_DURATION_S=1800
# Livello di log: DEBUG (output su stdout, sviluppo) | INFO | WARNING | ERROR.
LOG_LEVEL="INFO"
